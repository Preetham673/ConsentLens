<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="8dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#1E293B"
        app:strokeColor="#334155"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Top: decision badge + revocation status + time -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:id="@+id/txtDecision"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GRANTED"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#10B981"
                    android:background="@drawable/bg_audit_badge_green"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"/>

                <TextView
                    android:id="@+id/txtRevocationStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✔ Active"
                    android:textSize="10sp"
                    android:textColor="#10B981"
                    android:layout_marginStart="8dp"/>

                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

                <TextView
                    android:id="@+id/txtTimestamp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--:--"
                    android:textSize="10sp"
                    android:textColor="#475569"/>

            </LinearLayout>

            <!-- App package -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📦" android:textSize="12sp" android:layout_marginEnd="8dp"/>
                <TextView
                    android:id="@+id/txtPackage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="com.example.app"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#CBD5E1"
                    android:maxLines="1"
                    android:ellipsize="end"/>
            </LinearLayout>

            <!-- Risk + Jurisdiction -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">
                <TextView
                    android:id="@+id/txtRiskLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LOW RISK"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textColor="#10B981"
                    android:background="@drawable/bg_audit_badge_green"
                    android:paddingStart="8dp" android:paddingEnd="8dp"
                    android:paddingTop="3dp" android:paddingBottom="3dp"
                    android:layout_marginEnd="8dp"/>
                <TextView
                    android:id="@+id/txtJurisdiction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IN"
                    android:textSize="9sp"
                    android:textColor="#FBBF24"
                    android:background="@drawable/bg_audit_badge_amber"
                    android:paddingStart="8dp" android:paddingEnd="8dp"
                    android:paddingTop="3dp" android:paddingBottom="3dp"/>
            </LinearLayout>

            <!-- Divider -->
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#334155" android:layout_marginBottom="10dp"/>

            <!-- Purpose -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Purpose" android:textSize="10sp" android:textColor="#475569"/>
                <TextView
                    android:id="@+id/txtPurpose"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="—"
                    android:textSize="11sp"
                    android:textColor="#94A3B8"
                    android:maxLines="2"
                    android:ellipsize="end"/>
            </LinearLayout>

            <!-- Data Categories -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Data Categories" android:textSize="10sp" android:textColor="#475569"/>
                <TextView
                    android:id="@+id/txtDataCategories"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="—"
                    android:textSize="11sp"
                    android:textColor="#94A3B8"
                    android:maxLines="2"
                    android:ellipsize="end"/>
            </LinearLayout>

            <!-- Revoked -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Revoked" android:textSize="10sp" android:textColor="#475569"/>
                <TextView
                    android:id="@+id/txtRevoked"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="false"
                    android:textSize="11sp"
                    android:textColor="#94A3B8"/>
            </LinearLayout>

            <!-- Revoked Purposes -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Revoked Purposes" android:textSize="10sp" android:textColor="#475569"/>
                <TextView
                    android:id="@+id/txtRevokedPurposes"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="—"
                    android:textSize="11sp"
                    android:textColor="#94A3B8"
                    android:maxLines="2"
                    android:ellipsize="end"/>
            </LinearLayout>

            <!-- Divider -->
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#334155" android:layout_marginBottom="8dp"/>

            <!-- Hint -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tap for receipt  ·  Long press to revoke or erase"
                android:textSize="9sp"
                android:textColor="#334155"
                android:gravity="center"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>