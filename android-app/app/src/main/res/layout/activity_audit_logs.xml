<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F172A">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1E293B"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp">

        <!-- Top row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                app:cardCornerRadius="10dp"
                app:cardBackgroundColor="#334155"
                app:cardElevation="0dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="14dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="←"
                    android:textSize="17sp"
                    android:textColor="#94A3B8"
                    android:gravity="center"/>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/txtTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Audit Logs"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:textColor="#F1F5F9"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Compliance Trail · Organisation View"
                    android:textSize="10sp"
                    android:textColor="#64748B"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="38dp"
                android:layout_height="38dp"
                app:cardCornerRadius="10dp"
                app:cardBackgroundColor="#0F766E"
                app:cardElevation="0dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="📋"
                    android:textSize="18sp"
                    android:gravity="center"/>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Integrity status card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#0F172A"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="14dp"
            android:layout_marginBottom="0dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="38dp"
                android:layout_height="38dp"
                app:cardCornerRadius="10dp"
                app:cardBackgroundColor="#134E4A"
                app:cardElevation="0dp"
                android:layout_marginEnd="12dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="🔐"
                    android:textSize="18sp"
                    android:gravity="center"/>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Blockchain Integrity"
                    android:textSize="11sp"
                    android:textColor="#64748B"/>
                <TextView
                    android:id="@+id/txtIntegrityStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Verifying..."
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#94A3B8"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Live dot -->
            <View
                android:id="@+id/dotLive"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_dot_green"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LIVE"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#10B981"
                android:layout_marginStart="4dp"/>

        </LinearLayout>

    </LinearLayout>

    <!-- SECTION LABEL -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="10dp">

        <View
            android:layout_width="3dp"
            android:layout_height="14dp"
            android:background="#0D9488"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Recent Activity"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#94A3B8"
            android:letterSpacing="0.08"
            android:textAllCaps="true"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tamper-proof log"
            android:textSize="10sp"
            android:textColor="#475569"/>

    </LinearLayout>

    <!-- LOG LIST -->
    <ListView
        android:id="@+id/listLogs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@null"
        android:dividerHeight="0dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="20dp"
        android:clipToPadding="false"
        android:scrollbars="none"
        android:background="@android:color/transparent"/>

</LinearLayout>