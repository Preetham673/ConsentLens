<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="24dp">

    <!-- Icon -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="20dp"
        app:cardBackgroundColor="#FEE2E2"
        app:cardElevation="0dp">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="👨‍👧"
            android:textSize="28sp"
            android:gravity="center"/>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Guardian Consent Required"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#111827"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="You are under 18. A parent or guardian must verify this consent under DPDP law."
        android:textSize="13sp"
        android:textColor="#374151"
        android:gravity="center"
        android:lineSpacingExtra="3dp"
        android:layout_marginBottom="24dp"/>

    <!-- Email option -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardEmailOtp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#F0FDF4"
        app:strokeColor="#BBF7D0"
        app:strokeWidth="1dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="14dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📧"
                android:textSize="22sp"
                android:layout_marginEnd="14dp"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email OTP"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#166534"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Send a one-time code to parent's email"
                    android:textSize="12sp"
                    android:textColor="#15803D"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textSize="22sp"
                android:textColor="#16A34A"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- WhatsApp option -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardWhatsappOtp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#EFF6FF"
        app:strokeColor="#BFDBFE"
        app:strokeWidth="1dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="14dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💬"
                android:textSize="22sp"
                android:layout_marginEnd="14dp"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WhatsApp OTP"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#1D4ED8"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Send a one-time code via WhatsApp"
                    android:textSize="12sp"
                    android:textColor="#1D4ED8"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textSize="22sp"
                android:textColor="#2563EB"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ══════════════════════════════════════════════
         TWILIO SANDBOX SETUP INSTRUCTIONS BANNER
         ══════════════════════════════════════════════ -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#FFFBEB"
        app:strokeColor="#FDE68A"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Header row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠️"
                    android:textSize="16sp"
                    android:layout_marginEnd="8dp"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="WhatsApp Setup Required (First Time)"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#92400E"/>
            </LinearLayout>

            <!-- Step 1 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Before receiving a WhatsApp OTP, the parent's phone must be linked to our verification system."
                android:textSize="12sp"
                android:textColor="#78350F"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="10dp"/>

            <!-- Step label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="👆  One-time setup — parent must do this:"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#92400E"
                android:layout_marginBottom="8dp"/>

            <!-- Step box -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FEF3C7"
                android:padding="12dp">

                <!-- Step 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:text="1"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:background="@drawable/bg_step_circle_amber"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="  Open WhatsApp on parent's phone"
                        android:textSize="12sp"
                        android:textColor="#78350F"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Step 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:text="2"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:background="@drawable/bg_step_circle_amber"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="  Send this message to the number below:"
                        android:textSize="12sp"
                        android:textColor="#78350F"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Twilio number box -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#FFFFFF"
                    android:padding="10dp"
                    android:layout_marginStart="30dp"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Send to:"
                        android:textSize="10sp"
                        android:textColor="#9CA3AF"
                        android:layout_marginBottom="2dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+1 415 523 8886"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1D4ED8"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Message to send:"
                        android:textSize="10sp"
                        android:textColor="#9CA3AF"
                        android:layout_marginBottom="2dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="join using-five-house"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#065F46"
                        android:fontFamily="monospace"/>
                </LinearLayout>

                <!-- Step 3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:text="3"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:background="@drawable/bg_step_circle_amber"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="  Then tap WhatsApp OTP above to proceed"
                        android:textSize="12sp"
                        android:textColor="#78350F"
                        android:textStyle="bold"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <Button
        android:id="@+id/btnGuardianCancel"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Cancel"
        android:textSize="13sp"
        android:textColor="#374151"
        android:backgroundTint="#F3F4F6"
        style="@style/Widget.MaterialComponents.Button"
        app:cornerRadius="12dp"/>

</LinearLayout>