<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#0F172A"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:gravity="center"
        android:padding="30dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="Consent Provenance Graph"
            android:textColor="#22C55E"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="30dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- User -->
        <TextView
            android:text="User"
            android:background="#1E293B"
            android:textColor="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="↓"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- App -->
        <TextView
            android:id="@+id/txtGraphApp"
            android:text="App"
            android:background="#1E293B"
            android:textColor="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="↓"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Data -->
        <TextView
            android:id="@+id/txtGraphData"
            android:text="Data Categories"
            android:background="#1E293B"
            android:textColor="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="↓"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Purpose -->
        <TextView
            android:id="@+id/txtGraphPurpose"
            android:text="Purpose"
            android:background="#1E293B"
            android:textColor="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="↓"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Legal -->
        <TextView
            android:id="@+id/txtGraphLegal"
            android:text="Legal Basis"
            android:background="#1E293B"
            android:textColor="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="↓"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Retention -->
        <TextView
            android:id="@+id/txtGraphRetention"
            android:text="Retention"
            android:background="#1E293B"
            android:textColor="#FFFFFF"
            android:padding="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

</ScrollView>