<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:padding="16dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="AI Recommendation"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/txtRecommendation"
                    android:text="Review permissions and stay informed."/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>


        <Button
            android:id="@+id/btnGrant"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Grant Consent"
            android:backgroundTint="@color/risk_low"
            android:textColor="@android:color/white"/>


        <Button
            android:id="@+id/btnDeny"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Uninstall App"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/risk_high"
            android:textColor="@android:color/white"/>

    </LinearLayout>

</ScrollView>