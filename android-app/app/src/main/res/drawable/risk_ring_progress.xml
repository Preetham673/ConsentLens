<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape android:shape="ring" android:useLevel="false"
            android:innerRadiusRatio="2.8" android:thicknessRatio="12">
            <solid android:color="#1A2DD478"/>
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <rotate android:fromDegrees="-90" android:toDegrees="-90">
            <shape android:shape="ring" android:useLevel="true"
                android:innerRadiusRatio="2.8" android:thicknessRatio="12">
                <solid android:color="#2DD478"/>
            </shape>
        </rotate>
    </item>
</layer-list>