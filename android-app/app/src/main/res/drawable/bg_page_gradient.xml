<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Soft blue-white base -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#EEF2FF"/>
        </shape>
    </item>

    <!-- Subtle top tint -->
    <item android:bottom="600dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#E0E7FF"
                android:endColor="#EEF2FF"
                android:angle="270"
                android:type="linear"/>
        </shape>
    </item>

</layer-list>